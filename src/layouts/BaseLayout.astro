---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import CommandBar from '../components/CommandBar.astro';
import StatsBar from '../components/StatsBar.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  ogType?: 'website' | 'article';
  articlePublishedTime?: string;
  twitterCard?: 'summary' | 'summary_large_image';
}

const {
  title,
  description = 'Personal blog with emphasis on cloud-native technologies, by a Senior DevOps Engineer experienced in AWS, Kubernetes, Terraform, ArgoCD, and NixOS.',
  ogImage,
  canonicalUrl,
  ogType = 'website',
  articlePublishedTime,
  twitterCard,
} = Astro.props;

const siteTitle = 'Cloud Alchemist';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const canonical = canonicalUrl || Astro.url.href;
const resolvedTwitterCard = twitterCard || (ogImage ? 'summary_large_image' : 'summary');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="generator" content={Astro.generator} />

    <script is:inline>
      (() => {
        const storageKey = 'theme';
        const themeColors = {
          light: '#ffffff',
          dark: '#0a0a0a',
        };
        const root = document.documentElement;

        const readStoredTheme = () => {
          try {
            const storedTheme = window.localStorage.getItem(storageKey);
            return storedTheme === 'light' || storedTheme === 'dark' ? storedTheme : null;
          } catch {
            return null;
          }
        };

        const updateThemeColor = (theme) => {
          const themeColorMeta = document.querySelector('meta[name="theme-color"]');
          if (themeColorMeta) {
            themeColorMeta.setAttribute('content', themeColors[theme]);
          }
        };

        const applyTheme = (theme, persist) => {
          root.classList.toggle('dark', theme === 'dark');
          root.classList.toggle('light', theme === 'light');
          root.dataset.theme = theme;
          updateThemeColor(theme);

          if (persist) {
            try {
              window.localStorage.setItem(storageKey, theme);
            } catch {
              // Ignore storage failures.
            }
          }

          document.dispatchEvent(new CustomEvent('themechange', { detail: { theme } }));
        };

        const getPreferredTheme = () => readStoredTheme() || 'dark';
        const setTheme = (theme) => applyTheme(theme, true);
        const getTheme = () => root.classList.contains('dark') ? 'dark' : 'light';

        window.__themeController = {
          ...window.__themeController,
          sync: () => applyTheme(getPreferredTheme(), false),
          set: setTheme,
          get: getTheme,
        };
        window.__setTheme = setTheme;
        window.__getTheme = getTheme;

        window.__themeController.sync();

        if (!window.__themeControllerInitialized) {
          document.addEventListener('astro:after-swap', () => {
            window.__themeController?.sync();
          });
          window.__themeControllerInitialized = true;
        }
      })();
    </script>

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:site_name" content={siteTitle} />
    {ogType === 'article' && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content={resolvedTwitterCard} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Verification -->
    <meta
      name="google-site-verification"
      content="u3e2FAQkepx2zG0vhc4rR-MzwmmDI44fiUmwGJZWb-w"
    />
    <meta name="yandex-verification" content="6e30265145e14873" />

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteTitle}
      href="/feed.xml"
    />

    <!-- Preload monospace font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Google Analytics -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-P20LFSLH20"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-P20LFSLH20');
    </script>

    <ClientRouter />
  </head>
  <body class="bg-bg text-fg font-mono">
    <Header />
    <!-- Wider layout: max-w-wide (1100px) instead of max-w-4xl, reduced padding -->
    <main class="mx-auto w-full max-w-wide flex-1 px-4 sm:px-6 lg:px-8 py-6 pb-28">
      <slot />
    </main>
    <CommandBar />
    <StatsBar />
  </body>
</html>
