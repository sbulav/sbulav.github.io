---
// CommandBar: bottom vim-like command input with fuzzy search
// Commands: :help, :tags, :categories, :about, :cnp, :recent, :q, /search
import { getCollection } from 'astro:content';
import { getPostSlug, sortPostsByDate } from '../lib/utils';

const allPosts = sortPostsByDate(await getCollection('blog'));

// Build search index data for client-side Fuse.js
const searchIndex = allPosts.map((post) => ({
  title: post.data.title,
  slug: getPostSlug(post.id, post.data.categories),
  tags: post.data.tags.map((t: string) => t.toLowerCase()),
  categories: post.data.categories.map((c: string) => c.toLowerCase()),
  date: post.data.date.toISOString().split('T')[0],
}));
---

<div
  id="command-bar-wrapper"
  class="fixed right-0 bottom-10 left-0 z-40 pointer-events-none"
  transition:persist="command-bar"
>
  <div
    id="command-bar"
    class="pointer-events-auto mx-auto max-w-wide px-4 sm:px-6 lg:px-8"
  >
    <div
      class="rounded-lg border border-border bg-bg-secondary/95 p-2 backdrop-blur-lg shadow-lg"
    >
      <!-- Context path -->
      <span
        class="inline-block rounded border border-border bg-bg px-2 py-0.5 font-mono text-[10px] text-fg-dim"
        id="command-bar-path"
        >~/blog</span
      >

      <!-- Input row -->
      <div class="flex items-center gap-2 px-2 pt-1 pb-1 font-mono text-sm">
        <span class="text-accent" id="command-prompt">$</span>
        <input
          id="command-input"
          type="text"
          placeholder="Type ':help' or '/' to search"
          autocomplete="off"
          spellcheck="false"
          class="w-full border-none bg-transparent text-fg outline-none placeholder:text-fg-dim/50"
          aria-label="Command bar input"
        />
      </div>

      <!-- Results dropdown -->
      <div id="command-results" class="hidden max-h-64 overflow-y-auto">
        <!-- Populated by JS -->
      </div>

      <!-- Help overlay -->
      <div id="command-help" class="hidden">
        <div class="border-t border-border mt-1 pt-2 px-2 text-xs text-fg-muted space-y-1">
          <div><span class="text-tag">:help</span> — Show this help</div>
          <div><span class="text-tag">:tags</span> — Browse all tags</div>
          <div><span class="text-tag">:categories</span> — Browse all categories</div>
          <div><span class="text-tag">:about</span> — About page</div>
          <div><span class="text-tag">:cnp</span> — Calico Network Policy Visualiser</div>
          <div><span class="text-tag">:recent</span> — Recent posts</div>
          <div><span class="text-tag">:theme dark</span> / <span class="text-tag">:theme light</span> — Switch theme</div>
          <div><span class="text-tag">/text</span> — Search posts by title and tags</div>
          <div><span class="text-tag">Esc</span> — Close command bar</div>
          <div><span class="text-tag">:</span> or <span class="text-tag">/</span> — Open command bar (global)</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Search index data embedded in page -->
<script
  id="search-index-data"
  type="application/json"
  set:html={JSON.stringify(searchIndex)}
/>

<script>
  import Fuse from 'fuse.js';

  // Track abort controller for cleanup on view transitions
  let commandBarAbortController: AbortController | null = null;

  function initCommandBar() {
    // Clean up previous event listeners if they exist
    if (commandBarAbortController) {
      commandBarAbortController.abort();
    }
    commandBarAbortController = new AbortController();
    const signal = commandBarAbortController.signal;

    const wrapper = document.getElementById('command-bar-wrapper');
    const input = document.getElementById('command-input') as HTMLInputElement;
    const results = document.getElementById('command-results');
    const helpPanel = document.getElementById('command-help');
    const promptEl = document.getElementById('command-prompt');
    const pathEl = document.getElementById('command-bar-path');

    if (!wrapper || !input || !results || !helpPanel || !promptEl || !pathEl) return;

    const wrapperEl = wrapper;
    const resultsEl = results;
    const helpPanelEl = helpPanel;
    const promptElement = promptEl;
    const pathElement = pathEl;

    // Parse search index
    const indexEl = document.getElementById('search-index-data');
    let searchIndex: any[] = [];
    try {
      searchIndex = JSON.parse(indexEl?.textContent || '[]');
    } catch {
      searchIndex = [];
    }

    // Initialize Fuse.js
    const fuse = new Fuse(searchIndex, {
      keys: [
        { name: 'title', weight: 0.6 },
        { name: 'tags', weight: 0.3 },
        { name: 'categories', weight: 0.1 },
      ],
      threshold: 0.4,
      includeScore: true,
    });

    let isVisible = true;
    let isSearchMode = false;

    // Detect mobile/touch devices - hide by default
    const isTouchDevice = window.matchMedia('(pointer: coarse)').matches;
    const isSmallScreen = window.innerWidth < 768;
    if (isTouchDevice || isSmallScreen) {
      hideBar();
    }

    // Update context path based on current page
    const path = window.location.pathname;
    if (path === '/') {
      pathElement.textContent = '~/blog';
    } else {
      pathElement.textContent = '~' + path.replace(/\/$/, '');
    }

    const commands: Record<string, string> = {
      ':help': '__help__',
      ':tags': '/tags/',
      ':tag': '/tags/',
      ':categories': '/categories/',
      ':cat': '/categories/',
      ':about': '/about/',
      ':cnp': '/calico-visualiser/',
      ':home': '/',
      ':recent': '/posts/',
      ':blog': '/posts/',
      ':rss': '/feed.xml',
      ':theme dark': '__theme_dark__',
      ':theme light': '__theme_light__',
      ':q': '__hide__',
      ':quit': '__hide__',
    };

    function normalizeCommand(value: string): string {
      return value.trim().replace(/\s+/g, ' ').toLowerCase();
    }

    interface ThemeController {
      sync: () => void;
      set: (theme: 'light' | 'dark') => void;
      get: () => 'light' | 'dark';
    }

    function setTheme(theme: 'light' | 'dark') {
      const root = document.documentElement;

      // Always read theme APIs fresh from window at call time — never use a stale closure.
      const tw = window as Window & {
        __themeController?: ThemeController;
        __setTheme?: (value: 'light' | 'dark') => void;
      };

      if (typeof tw.__themeController?.set === 'function') {
        tw.__themeController.set(theme);
        return;
      }

      if (typeof tw.__setTheme === 'function') {
        tw.__setTheme(theme);
        return;
      }

      // Final fallback: manipulate DOM directly and persist to localStorage.
      root.classList.toggle('dark', theme === 'dark');
      root.classList.toggle('light', theme === 'light');
      root.dataset.theme = theme;
      try { window.localStorage.setItem('theme', theme); } catch { /* ignore */ }
      document.dispatchEvent(new CustomEvent('themechange', { detail: { theme } }));
    }

    function showResults(items: typeof searchIndex) {
      helpPanelEl.classList.add('hidden');
      if (items.length === 0) {
        resultsEl.innerHTML =
          '<div class="px-2 py-2 text-xs text-fg-muted">No results found</div>';
        resultsEl.classList.remove('hidden');
        return;
      }

      resultsEl.innerHTML = items
        .map(
          (item, i) => `
        <a href="/${item.slug}/"
          class="flex items-center gap-3 px-2 py-1.5 text-xs hover:bg-bg-tertiary rounded transition-colors ${i === 0 ? 'bg-bg-tertiary' : ''}"
          data-result-index="${i}">
          <span class="text-date shrink-0">${item.date}</span>
          <span class="text-fg truncate flex-1">${item.title}</span>
          <span class="text-fg-dim shrink-0">${item.categories.join('/')}</span>
        </a>`
        )
        .join('');
      resultsEl.classList.remove('hidden');
    }

    function hideResults() {
      resultsEl.classList.add('hidden');
      resultsEl.innerHTML = '';
    }

    function showHelp() {
      hideResults();
      helpPanelEl.classList.remove('hidden');
    }

    function hideHelp() {
      helpPanelEl.classList.add('hidden');
    }

    function hideBar() {
      wrapperEl.style.display = 'none';
      isVisible = false;
      input.blur();
    }

    function showBar() {
      wrapperEl.style.display = '';
      isVisible = true;
    }

    function navigate(url: string) {
      input.value = '';
      hideResults();
      hideHelp();
      // Use view transitions navigation
      if ((window as any).navigation && typeof (window as any).navigation.navigate === 'function') {
        (window as any).navigation.navigate(url);
      } else {
        window.location.href = url;
      }
    }

    function executeCommand(command: string): boolean {
      const action = commands[normalizeCommand(command)];

      if (!action) {
        return false;
      }

      if (action === '__help__') {
        showHelp();
        return true;
      }

      if (action === '__hide__') {
        hideBar();
        input.value = '';
        hideResults();
        hideHelp();
        return true;
      }

      if (action === '__theme_dark__' || action === '__theme_light__') {
        const targetTheme = action === '__theme_dark__' ? 'dark' : 'light';
        // Clear UI first so blur doesn't race with theme application.
        input.value = '';
        hideResults();
        hideHelp();
        // Apply theme after UI is cleared so no stale focus state interferes.
        setTheme(targetTheme);
        hideBar();
        return true;
      }

      navigate(action);
      return true;
    }

    // Handle input changes
    input.addEventListener('input', () => {
      const val = input.value;
      const normalizedVal = normalizeCommand(val);

      if (normalizedVal === ':help') {
        showHelp();
        return;
      }

      hideHelp();

      if (val.startsWith('/') && val.length > 1) {
        // Search mode
        isSearchMode = true;
        promptElement.textContent = '/';
        const query = val.slice(1);
        const fuseResults = fuse.search(query, { limit: 10 });
        showResults(fuseResults.map((r) => r.item));
      } else if (val.startsWith(':')) {
        isSearchMode = false;
        promptElement.textContent = ':';
        const matchingCmds = Object.entries(commands).filter(([cmd]) =>
          cmd.startsWith(normalizedVal)
        );
        if (matchingCmds.length > 0 && normalizedVal.length > 1) {
          resultsEl.innerHTML = matchingCmds
            .filter(([, dest]) => dest !== '__help__' && dest !== '__hide__')
            .map(
              ([cmd, dest], i) => `
            <button
              type="button"
              class="flex w-full items-center gap-3 rounded px-2 py-1.5 text-left text-xs transition-colors hover:bg-bg-tertiary ${i === 0 ? 'bg-bg-tertiary' : ''}"
              data-result-index="${i}"
              data-command="${cmd}">
              <span class="text-tag shrink-0">${cmd}</span>
              <span class="text-fg-dim">${dest === '__theme_dark__' ? 'switch to dark theme' : dest === '__theme_light__' ? 'switch to light theme' : dest}</span>
            </button>`
            )
            .join('');
          resultsEl.classList.remove('hidden');
        } else {
          hideResults();
        }
      } else {
        isSearchMode = false;
        promptElement.textContent = '$';
        hideResults();
      }
    }, { signal });

    // Handle key events
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        const val = input.value.trim();
        const normalizedVal = normalizeCommand(val);

        if (executeCommand(normalizedVal)) {
          return;
        }

        const firstResult = resultsEl.querySelector('[data-result-index="0"]') as HTMLElement | null;
        if (firstResult) {
          if (firstResult instanceof HTMLAnchorElement) {
            navigate(firstResult.getAttribute('href') || '/');
          } else if (firstResult.dataset.command) {
            executeCommand(firstResult.dataset.command);
          }
          return;
        }

        // Search mode - trigger search
        if (val.startsWith('/') && val.length > 1) {
          const query = val.slice(1);
          const fuseResults = fuse.search(query, { limit: 10 });
          if (fuseResults.length > 0) {
            navigate('/' + fuseResults[0].item.slug);
          }
        }
      }

      if (e.key === 'Escape') {
        e.preventDefault();
        input.value = '';
        hideResults();
        hideHelp();
        promptElement.textContent = '$';
        input.blur();
      }

      // Navigate results with arrow keys
      if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
        e.preventDefault();
        const resultItems = resultsEl.querySelectorAll('[data-result-index]');
        if (resultItems.length === 0) return;

        const current = resultsEl.querySelector('.bg-bg-tertiary');
        let idx = -1;
        if (current) {
          idx = Array.from(resultItems).indexOf(current as HTMLElement);
        }

        if (e.key === 'ArrowDown') idx = Math.min(idx + 1, resultItems.length - 1);
        else idx = Math.max(idx - 1, 0);

        resultItems.forEach((item) => item.classList.remove('bg-bg-tertiary'));
        resultItems[idx]?.classList.add('bg-bg-tertiary');
        resultItems[idx]?.scrollIntoView({ block: 'nearest' });
      }

      if (e.key === 'Tab') {
        e.preventDefault();
        const currentValue = input.value;
        if (currentValue.startsWith(':')) {
          const normalizedVal = normalizeCommand(currentValue);
          const match = Object.keys(commands).find((cmd) =>
            cmd.startsWith(normalizedVal)
          );
          if (match) {
            input.value = match;
            input.dispatchEvent(new Event('input'));
          }
        }
      }
    }, { signal });

    resultsEl.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const commandButton = target.closest('[data-command]') as HTMLButtonElement | null;

      if (commandButton?.dataset.command) {
        e.preventDefault();
        executeCommand(commandButton.dataset.command);
      }
    }, { signal });

    // Global keyboard shortcuts to open command bar
    document.addEventListener('keydown', (e) => {
      const target = e.target as HTMLElement;
      if (
        target.tagName === 'INPUT' ||
        target.tagName === 'TEXTAREA' ||
        target.isContentEditable
      ) {
        return;
      }

      if (e.key === '/' || e.key === ':') {
        e.preventDefault();
        showBar();
        input.focus();
        input.value = e.key === '/' ? '/' : ':';
        promptElement.textContent = e.key === '/' ? '/' : ':';
        input.dispatchEvent(new Event('input'));
      }

      if (e.key === 'Escape' && isVisible) {
        hideBar();
      }
    }, { signal });
  }

  // Initialize on load and after view transitions
  initCommandBar();
  document.addEventListener('astro:after-swap', initCommandBar);
</script>
