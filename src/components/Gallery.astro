---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface GalleryItem {
  name: string;
  icon?: ImageMetadata | string;
}

interface Props {
  title: string;
  items: GalleryItem[];
}

const { title, items } = Astro.props;
---

<div class="mb-8">
  <h3 class="mb-3 font-mono text-sm font-semibold text-accent">
    $ ls {title.toLowerCase()}/
  </h3>
  <div class="grid grid-cols-3 gap-3 sm:grid-cols-4 md:grid-cols-6">
    {items.map(item => (
      <div class="flex flex-col items-center gap-2 rounded-lg border border-border bg-bg-secondary/50 p-3 transition-colors hover:border-accent/50 hover:bg-bg-secondary">
        {item.icon && (
          typeof item.icon === 'string'
            ? <img src={item.icon} alt={item.name} class="h-8 w-8 object-contain" loading="lazy" />
            : <Image src={item.icon} alt={item.name} class="h-8 w-8 object-contain" loading="lazy" width={32} height={32} />
        )}
        <span class="text-center font-mono text-xs text-fg-dim">
          {item.name}
        </span>
      </div>
    ))}
  </div>
</div>
