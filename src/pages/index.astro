---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import GitHubStatsProvider from '../components/GitHubStatsProvider.astro';
import GitHubMobileProfile from '../components/GitHubMobileProfile.astro';
import PostCard from '../components/PostCard.astro';
import Pagination from '../components/Pagination.astro';
import Sidebar from '../components/Sidebar.astro';
import { sortPostsByDate, getPostSlug } from '../lib/utils';

const POSTS_PER_PAGE = 5;
const allPosts = sortPostsByDate(await getCollection('blog'));
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const posts = allPosts.slice(0, POSTS_PER_PAGE);
---

<GitHubStatsProvider>
  <BaseLayout title="Cloud Alchemist">
    <div class="relative">
      <Sidebar />

      <!-- Posts list - full width, same as before -->
      <div>
        <!-- Mobile profile (visible only on small screens) -->
        <GitHubMobileProfile />

        <div class="mb-6">
          <div class="font-mono text-xs text-fg-dim">
            <span class="text-accent">~/blog</span>
            <span> $ </span>
            <span class="text-fg">ls -lt recent_posts/</span>
          </div>
        </div>

        <div class="space-y-3">
          {posts.map(post => (
            <PostCard
              title={post.data.title}
              date={post.data.date}
              categories={post.data.categories}
              tags={post.data.tags}
              slug={getPostSlug(post.id, post.data.categories)}
              body={post.body || ''}
            />
          ))}
        </div>

        <Pagination currentPage={1} totalPages={totalPages} />
      </div>
    </div>
  </BaseLayout>
</GitHubStatsProvider>
